<UserControl x:Class="MVXTester.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:vm="clr-namespace:MVXTester.App.ViewModels"
             xmlns:conv="clr-namespace:MVXTester.App.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />

        <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
            <nodify:NodeInput Header="{Binding DisplayName}"
                              Anchor="{Binding Anchor, Mode=OneWayToSource}"
                              IsConnected="{Binding IsConnected}"
                              BorderBrush="{DynamicResource AccentBrush}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <nodify:LineConnection Source="{Binding Source.Anchor}"
                                   Target="{Binding Target.Anchor}"
                                   Stroke="{DynamicResource AccentBrush}"
                                   StrokeThickness="2" />
        </DataTemplate>
    </UserControl.Resources>

    <nodify:NodifyEditor x:Name="Editor"
                         ItemsSource="{Binding Nodes}"
                         Connections="{Binding Connections}"
                         PendingConnection="{Binding PendingConnection}"
                         SelectedItems="{Binding SelectedNodes}"
                         ItemsDragStartedCommand="{Binding ItemsDragStartedCommand}"
                         ItemsDragCompletedCommand="{Binding ItemsDragCompletedCommand}"
                         Background="#1E1E2E"
                         GridCellSize="20"
                         DisableAutoPanning="False">

        <nodify:NodifyEditor.PendingConnectionTemplate>
            <DataTemplate DataType="{x:Type vm:PendingConnectionViewModel}">
                <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                          CompletedCommand="{Binding FinishCommand}"
                                          Stroke="{DynamicResource WarningBrush}"
                                          StrokeThickness="2"
                                          StrokeDashArray="4 2"
                                          Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
            </DataTemplate>
        </nodify:NodifyEditor.PendingConnectionTemplate>

        <nodify:NodifyEditor.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                <nodify:Node Header="{Binding Title}"
                             Input="{Binding InputConnectors}"
                             Output="{Binding OutputConnectors}"
                             HeaderBrush="{Binding CategoryColor}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1">
                    <nodify:Node.Footer>
                        <StackPanel>
                            <Image Source="{Binding PreviewImage}"
                                   MaxWidth="160" MaxHeight="120"
                                   Stretch="Uniform" Margin="4"
                                   Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}" />
                            <Border Background="#40F38BA8" CornerRadius="2" Padding="4,2" Margin="4,0,4,4"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}">
                                <TextBlock Text="{Binding ErrorMessage}" FontSize="10"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           TextWrapping="Wrap" MaxWidth="160" />
                            </Border>
                        </StackPanel>
                    </nodify:Node.Footer>

                    <nodify:Node.InputConnectorTemplate>
                        <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                            <nodify:NodeInput Header="{Binding DisplayName}"
                                              Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                              IsConnected="{Binding IsConnected}"
                                              Foreground="{DynamicResource ForegroundDimBrush}"
                                              FontSize="10"
                                              BorderBrush="{Binding TypeColor}" />
                        </DataTemplate>
                    </nodify:Node.InputConnectorTemplate>

                    <nodify:Node.OutputConnectorTemplate>
                        <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                            <nodify:NodeOutput Header="{Binding DisplayName}"
                                               Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                               IsConnected="{Binding IsConnected}"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               FontSize="10"
                                               BorderBrush="{Binding TypeColor}" />
                        </DataTemplate>
                    </nodify:Node.OutputConnectorTemplate>
                </nodify:Node>
            </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>

        <nodify:NodifyEditor.ItemContainerStyle>
            <Style TargetType="{x:Type nodify:ItemContainer}">
                <Setter Property="Location" Value="{Binding Location}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected}" />
            </Style>
        </nodify:NodifyEditor.ItemContainerStyle>

        <nodify:NodifyEditor.ConnectionTemplate>
            <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                <nodify:CircuitConnection Source="{Binding Source.Anchor}"
                                          Target="{Binding Target.Anchor}"
                                          Stroke="{Binding Source.TypeColor}"
                                          StrokeThickness="2"
                                          MouseRightButtonDown="Connection_MouseRightButtonDown" />
            </DataTemplate>
        </nodify:NodifyEditor.ConnectionTemplate>
    </nodify:NodifyEditor>
</UserControl>
