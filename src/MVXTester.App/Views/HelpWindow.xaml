                                    </Border>
                                    <TextBlock Text="   Save as .mvxp" FontSize="9" Foreground="{DynamicResource ForegroundDimBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <!-- Step B: Import as function -->
                                <TextBlock Text="2. Import &#x2192; Use as single node:" FontSize="9" Foreground="{DynamicResource ForegroundDimBrush}" Margin="0,10,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="8,4">
                                        <TextBlock Text="Image Read" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="4" BorderThickness="2" BorderBrush="#FFCF48" Background="#30FFCF48" Padding="10,5">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="My Function" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Function Node" FontSize="7.5" Foreground="#FFCF48" HorizontalAlignment="Center" Margin="0,1,0,0"/>
