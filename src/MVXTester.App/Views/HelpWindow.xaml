                                        <TextBlock Text="Test Image" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="&#x2197;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0"/>
                                <!-- Center: Defect Detector -->
                                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" CornerRadius="4" BorderThickness="1.5" BorderBrush="#9399B2" Background="#309399B2" Padding="10,5" VerticalAlignment="Center">
