                                        <TextBlock Text="Inspection" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="3" Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
