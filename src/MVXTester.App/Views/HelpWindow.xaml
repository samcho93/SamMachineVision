<Window x:Class="MVXTester.App.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SamMachineVision — Help" Width="1000" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <!-- Help-specific styles (must be before content that references them) -->
    <Window.Resources>
        <Style x:Key="HelpH1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="HelpH2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Margin" Value="0,16,0,6" />
        </Style>
        <Style x:Key="HelpH3" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
        <Style x:Key="HelpBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="HelpKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style x:Key="HelpKeyDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="Margin" Value="8,2,0,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="SamMachineVision" FontWeight="Bold" FontSize="22"
                           Foreground="{DynamicResource ForegroundBrush}" />
                <TextBlock Text="Node-Based Visual Programming for Computer Vision"
                           FontSize="12" Foreground="{DynamicResource ForegroundDimBrush}" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" Margin="0" Padding="0" BorderThickness="0">

            <!-- ═══ Tab 1: Usage ═══ -->
            <TabItem Header="  Usage  " Padding="8,4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HelpH1}">Basic Usage</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">SamMachineVision is a node-based visual programming environment for building computer vision pipelines. Connect nodes to create image processing workflows without writing code.</TextBlock>

                        <TextBlock Style="{StaticResource HelpH2}">Getting Started</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">1. Drag a node from the Node Palette (left panel) onto the canvas
2. Connect nodes by dragging from an output port (right) to an input port (left)
3. Configure node parameters in the Properties panel (right)
4. Press F5 to execute or enable Auto Execute</TextBlock>

                        <TextBlock Style="{StaticResource HelpH2}">Execution Modes</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve"><Bold>▶ Execute (F5)</Bold> — Runtime mode. Runs continuously, re-executing only when nodes become dirty (properties change, inputs update). Ideal for interactive parameter tuning.

<Bold>Force Execute (Ctrl+F5)</Bold> — Single-shot execution. Forces all nodes to re-process regardless of dirty state.

<Bold>Stream (F6)</Bold> — Continuous streaming mode. Runs at maximum FPS, re-executing every frame. Used for live camera feeds and real-time processing.

<Bold>Auto Execute</Bold> — When checked, automatically re-executes the graph when any property changes (with 150ms debounce).</TextBlock>

                        <TextBlock Style="{StaticResource HelpH2}">Keyboard Shortcuts</TextBlock>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+N</TextBlock>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">New Graph</TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+O</TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Open Project</TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+S</TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Save</TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+Shift+S</TextBlock>
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Save As</TextBlock>
                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource HelpKey}">F5</TextBlock>
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Execute / Stop Runtime</TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+F5</TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Force Execute (all nodes)</TextBlock>
                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource HelpKey}">F6</TextBlock>
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Toggle Streaming</TextBlock>
                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource HelpKey}">Escape</TextBlock>
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Cancel Execution</TextBlock>
                            <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource HelpKey}">Delete</TextBlock>
                            <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Delete Selected Nodes</TextBlock>
                            <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+Z / Ctrl+Y</TextBlock>
                            <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Undo / Redo</TextBlock>
                            <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+C / Ctrl+V</TextBlock>
                            <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Copy / Paste Nodes</TextBlock>
                            <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+D</TextBlock>
                            <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Duplicate Selected</TextBlock>
                            <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource HelpKey}">Ctrl+A</TextBlock>
                            <TextBlock Grid.Row="12" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Select All</TextBlock>
                            <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource HelpKey}">Double-Click Node</TextBlock>
                            <TextBlock Grid.Row="13" Grid.Column="1" Style="{StaticResource HelpKeyDesc}">Open file picker (Image/Video nodes) or Function detail</TextBlock>
                        </Grid>

                        <TextBlock Style="{StaticResource HelpH2}">Node Connections</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">• Each input port accepts only one connection (previous connection is replaced)
• Output ports can connect to multiple input ports
• Connections enforce type compatibility (e.g., Mat to Mat, int to int)
• Cycles are automatically detected and prevented
• Data flows left to right: Output → Input (pull-based)</TextBlock>

                        <TextBlock Style="{StaticResource HelpH2}">Saving Projects</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve"><Bold>.mvxp</Bold> — Project archive (ZIP). Includes graph JSON + referenced image/video files. Recommended format for sharing.
<Bold>.mvx</Bold> — Legacy JSON format. Graph only, no embedded files.</TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 2: Tutorial ═══ -->
            <TabItem Header="  Tutorial  " Padding="8,4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HelpH1}">Tutorials</TextBlock>

                        <!-- ── Tutorial 1: Basic Image Processing ── -->
                        <TextBlock Style="{StaticResource HelpH2}">Tutorial 1: Basic Image Processing</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">Goal: Load an image, convert to grayscale, apply blur, detect edges.</TextBlock>

                        <!-- Node Diagram -->
                        <Border Background="{DynamicResource HighlightBrush}" CornerRadius="6" Padding="14,10" Margin="0,6,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Image Read -->
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Image Read" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Input/Output" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <!-- Convert Color -->
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#CBA6F7" Background="#30CBA6F7" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Convert Color" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="BGR2GRAY" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <!-- Gaussian Blur -->
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#89B4FA" Background="#3089B4FA" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Gaussian Blur" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Kernel=5" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <!-- Canny -->
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#F38BA8" Background="#30F38BA8" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Canny" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Edge Detection" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">Step 1: Add an "Image Read" node from Input/Output category
Step 2: Double-click the node to select an image file
Step 3: Add a "Convert Color" node (Color), set Code = BGR2GRAY
Step 4: Connect Image Read &#x2192; Convert Color
Step 5: Add a "Gaussian Blur" node (Filter), set KernelW/H = 5
Step 6: Add a "Canny" node (Edge Detection), Threshold1=100, Threshold2=200
Step 7: Connect all nodes left-to-right, press F5 to execute</TextBlock>

                        <!-- ── Tutorial 2: Contour Detection ── -->
                        <TextBlock Style="{StaticResource HelpH2}">Tutorial 2: Object Detection with Contours</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">Goal: Find and count objects in a binary image.</TextBlock>

                        <!-- Node Diagram -->
                        <Border Background="{DynamicResource HighlightBrush}" CornerRadius="6" Padding="14,10" Margin="0,6,0,8">
                            <StackPanel>
                                <!-- Row 1 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="8,5">
                                        <TextBlock Text="Image Read" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#CBA6F7" Background="#30CBA6F7" Padding="8,5">
                                        <TextBlock Text="CvtColor" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#F9E2AF" Background="#30F9E2AF" Padding="8,5">
                                        <TextBlock Text="Threshold" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#A6E3A1" Background="#30A6E3A1" Padding="8,5">
                                        <TextBlock Text="Find Contours" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                </StackPanel>
                                <!-- Row 2 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock Text="&#x2193;" FontSize="14" Foreground="#FAB387" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#A6E3A1" Background="#30A6E3A1" Padding="8,5">
                                        <TextBlock Text="Filter Contours" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="16" Foreground="#FAB387" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#F5C2E7" Background="#30F5C2E7" Padding="8,5">
                                        <TextBlock Text="Draw Contours" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="&#x2192;" FontSize="16" Foreground="#F9E2AF" VerticalAlignment="Center" Margin="4,0"/>
                                    <Border CornerRadius="3" BorderThickness="1" BorderBrush="{DynamicResource ForegroundDimBrush}" Padding="8,4">
                                        <TextBlock Text="Count: N" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">Step 1: Image Read &#x2192; Convert Color (BGR2GRAY) &#x2192; Threshold (Thresh=128)
Step 2: Add "Find Contours" node (Contour category)
Step 3: Add "Filter Contours", set MinArea=500 to remove noise
Step 4: Add "Draw Contours", connect original image + filtered contours
Step 5: The Count output tells you how many objects were found</TextBlock>

                        <!-- ── Tutorial 3: Live Camera ── -->
                        <TextBlock Style="{StaticResource HelpH2}">Tutorial 3: Live Camera Processing</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">Goal: Process live camera feed in real-time.</TextBlock>

                        <!-- Node Diagram -->
                        <Border Background="{DynamicResource HighlightBrush}" CornerRadius="6" Padding="14,10" Margin="0,6,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Camera" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="USB / HIK / Cognex" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#89B4FA" Background="#3089B4FA" Padding="10,5">
                                    <TextBlock Text="Gaussian Blur" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#F9E2AF" Background="#30F9E2AF" Padding="10,5">
                                    <TextBlock Text="Threshold" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#A6E3A1" Background="#30A6E3A1" Padding="10,5">
                                    <TextBlock Text="Find Contours" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>
                                <TextBlock Text="  F6" FontSize="11" FontWeight="Bold" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">Step 1: Add a "Camera" node from Input category
Step 2: Click Refresh to detect all connected cameras (USB, HIK, Cognex)
Step 3: Select a camera &#x2014; properties auto-adjust for the camera type
Step 4: Connect to processing nodes (blur, threshold, etc.)
Step 5: Press F6 (Stream) to start continuous capture
Step 6: Adjust parameters in real-time &#x2014; results update live
Step 7: Press F6 again to stop streaming</TextBlock>

                        <!-- ── Tutorial 4: Template Matching ── -->
                        <TextBlock Style="{StaticResource HelpH2}">Tutorial 4: Template Matching</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">Goal: Find a template pattern in a larger image.</TextBlock>

                        <!-- Node Diagram (two inputs merging) -->
                        <Border Background="{DynamicResource HighlightBrush}" CornerRadius="6" Padding="14,10" Margin="0,6,0,8">
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Top input: Scene -->
                                <Border Grid.Row="0" Grid.Column="0" CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Image Read" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Scene" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="&#x2198;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0"/>
                                <!-- Bottom input: Template -->
                                <Border Grid.Row="2" Grid.Column="0" CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Image Read" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Template" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="&#x2197;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0"/>
                                <!-- Center: Template Match -->
                                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" CornerRadius="4" BorderThickness="1.5" BorderBrush="#F2CDCD" Background="#30F2CDCD" Padding="10,5" VerticalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Template Match" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CCoeffNormed" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="3" Text="&#x2192;" FontSize="16" Foreground="#89B4FA" VerticalAlignment="Center" Margin="5,0"/>
                                <!-- Outputs -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="4" VerticalAlignment="Center">
                                    <Border CornerRadius="3" BorderThickness="1" BorderBrush="{DynamicResource ForegroundDimBrush}" Padding="8,3" Margin="0,0,0,4">
                                        <TextBlock Text="Location (Point)" FontSize="9" FontFamily="Consolas" Foreground="#F5C2E7"/>
                                    </Border>
                                    <Border CornerRadius="3" BorderThickness="1" BorderBrush="{DynamicResource ForegroundDimBrush}" Padding="8,3">
                                        <TextBlock Text="Score (double)" FontSize="9" FontFamily="Consolas" Foreground="#F9E2AF"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Style="{StaticResource HelpBody}" xml:space="preserve">Step 1: Add two "Image Read" nodes &#x2014; one for scene, one for template
Step 2: Add "Template Match" node (Detection category)
Step 3: Connect scene &#x2192; Image, template &#x2192; Template input
Step 4: Set Method = CCoeffNormed for best results
Step 5: Outputs: Location (best match) and Score (0~1)
Step 6: For multiple matches, use "Template Match Multi" with Threshold=0.8</TextBlock>

                        <!-- ── Tutorial 5: Control Flow ── -->
                        <TextBlock Style="{StaticResource HelpH2}">Tutorial 5: Using Control Flow (Loops)</TextBlock>
                        <TextBlock Style="{StaticResource HelpBody}">Goal: Process multiple images with the same pipeline using For loop.</TextBlock>

                        <!-- Node Diagram -->
                        <Border Background="{DynamicResource HighlightBrush}" CornerRadius="6" Padding="14,10" Margin="0,6,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#74C7EC" Background="#3074C7EC" Padding="10,5">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="For" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Start=0, End=5" FontSize="7.5" Foreground="{DynamicResource ForegroundDimBrush}" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="&#x2192;" FontSize="16" Foreground="#F9E2AF" VerticalAlignment="Center" Margin="5,0"/>
                                <!-- Loop body (labeled border) -->
                                <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#609399B2" Background="#109399B2" Padding="6,5">
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#89B4FA" Background="#3089B4FA" Padding="8,4">
                                            <TextBlock Text="Blur" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                        </Border>
                                        <TextBlock Text="&#x2192;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                        <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#F9E2AF" Background="#30F9E2AF" Padding="8,4">
                                            <TextBlock Text="Threshold" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                        </Border>
                                        <TextBlock Text="&#x2192;" FontSize="14" Foreground="#89B4FA" VerticalAlignment="Center" Margin="4,0"/>
                                        <Border CornerRadius="4" BorderThickness="1.5" BorderBrush="#A6E3A1" Background="#30A6E3A1" Padding="8,4">
                                            <TextBlock Text="Contours" FontSize="9.5" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
